@{
	Layout = "_Layout";
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model eCommerceTP1.Models.Panier
<h1>Votre panier</h1>
<table class="table table-striped">
	<thead>
		<tr>
			<th scope="col">#</th>
			<th scope="col">Nom</th>
			<th scope="col">Quantite</th>
			<th scope="col">Prix</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var produitPanier in Model.ProduitsPanier)
		{
			<tr>
				<form method="post">
				<th scope="row">@produitPanier.ProduitId</th>
				<td><a asp-controller="DashboardClient"
                       asp-action="DetailProduit"
					   asp-route-id="@produitPanier.ProduitId">@produitPanier.Produit.Title</a>
				</td>
				<td>
					<button class="btn btn-success btn-sm"
							asp-controller="Panier"
							asp-action="AddProduitToPanier"
							asp-route-id="@produitPanier.ProduitId"
							asp-route-reloadPage="true"
							type="submit"
					>
					+
					</button>
					@produitPanier.Quantite
					<button class="btn btn-danger btn-sm"
						asp-controller="Panier"
						asp-action="RemoveProduitFromPanier"
						asp-route-id="@produitPanier.ProduitId"
						asp-route-reloadPage="true"
						type="submit"
					>
					-
					</button>
				</td>
				<td>@(Math.Round(produitPanier.Produit.Price * produitPanier.Quantite, 2) + " $")</td>
				</form>
			</tr>
		}
	</tbody>
	<tfoot>
		<tr>
			<th scope="row">Total</th>
			<td></td>
			<td></td>
			<td>@(Math.Round(Model.ProduitsPanier.Sum(prodPanier => prodPanier.Produit.Price * prodPanier.Quantite),2) + " $")</td>
		</tr>
	</tfoot>
</table>

<a asp-controller="Panier" asp-action="Recap" class="btn btn-primary">
	Commander
</a>