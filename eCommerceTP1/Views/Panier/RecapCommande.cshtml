@model eCommerceTP1.Models.Panier
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_Layout";
}

<h1>Récapitulatif de votre commande</h1>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Produit</th>
            <th>Quantité</th>
            <th>Prix unitaire</th>
            <th>Sous-total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var produitPanier in Model.ProduitsPanier)
        {
            <tr>
                <td>
                    <a asp-controller="DashboardClient"
                       asp-action="DetailProduit"
                       asp-route-id="@produitPanier.ProduitId">
                        @produitPanier.Produit.Title
                    </a>
                </td>
                <td>@produitPanier.Quantite</td>
                <td>@Math.Round(produitPanier.Produit.Price, 2) $</td>
                <td>@Math.Round(produitPanier.Produit.Price * produitPanier.Quantite, 2) $</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="3" class="text-end">Total :</th>
            <th>
                @Math.Round(Model.ProduitsPanier.Sum(p => p.Produit.Price * p.Quantite), 2) $
            </th>
        </tr>
    </tfoot>
</table>

<div class="mt-3">
    <a asp-controller="Panier" asp-action="Index" class="btn btn-secondary">
        Retour au panier
    </a>

    <a asp-controller="Paiement" asp-action="Index" class="btn btn-primary">
        Confirmer la commande
    </a>
</div>