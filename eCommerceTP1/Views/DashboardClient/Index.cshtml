@model List<eCommerceTP1.Models.Produit>

@{
    Layout = "_Layout";
}


<h2 class="mb-4 text-primary">Dashboard Client</h2>

<div class="row">
    @if (Model != null && Model.Any())
    {
        @foreach (var product in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <img src="@product.Image" class="card-img-top" style="height:200px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Title</h5>
                        <p class="card-text">
                            @product.Description.Substring(0, Math.Min(product.Description.Length, 80))...
                        </p>

                        <p class="fw-bold text-primary mt-auto">
                            @product.Price $
                        </p>

                        <a href="#" class="btn btn-outline-primary w-100">
                            Voir produit
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <p>Aucun produit trouvé.</p>
    }
</div>